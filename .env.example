# Copy to `.env.local` and adjust (`.env.local` is gitignored).
#
# To disable Next.js telemetry:
# Set NEXT_TELEMETRY_DISABLED=1 in `.env.local` to disable.
#
# Mock UI data (default) — safe for design / Playwright:
# NEXT_PUBLIC_USE_MOCK=true
#
# Real Conceal wallet (IndexedDB + public daemons):
NEXT_PUBLIC_USE_MOCK=false

# GitHub Pages subpath when exporting (CI sets this):
# PAGES_BASE_PATH=/conceal-next-wallet
# NEXT_PUBLIC_PAGES_BASE_PATH=/conceal-next-wallet
