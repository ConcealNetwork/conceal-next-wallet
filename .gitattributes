# Normalize text files to LF in the repo (Unix line endings).
* text=auto eol=lf

# Shell scripts must stay LF for shebangs on Linux/macOS.
*.sh text eol=lf

# Binary assets — do not line-ending-normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
*.zip binary
*.tgz binary
*.wasm binary
