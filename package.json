{
  "name": "conceal-next-wallet",
  "version": "0.1.0",
  "private": true,
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "generate:precache": "node scripts/generate-precache-manifest.mjs",
    "dev": "next dev",
    "preflight": "npm run types && npm run test && npm run lint && npm run format && npm run check",
    "build": "NODE_OPTIONS=--no-deprecation next build && npm run generate:precache",
    "cordova": "node scripts/cordova-postprocess.mjs --build ../conceal-wallet-cordova",
    "start": "next start",
    "types": "tsc --noEmit",
    "format": "npx biome format",
    "format:fix": "npx biome format --write",
    "lint": "npx biome lint",
    "lint:fix": "npx biome lint --write",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "test": "NODE_OPTIONS=--no-deprecation vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "conceal-wallet-sdk": "https://github.com/ConcealNetwork/conceal-wallet-sdk/releases/download/v0.2.12/conceal-wallet-sdk-0.2.12.tgz",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.11",
    "qrcode-generator": "^2.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "dompurify": "3.4.12",
    "sharp": "0.35.3",
    "undici": "7.28.0"
  }
}
